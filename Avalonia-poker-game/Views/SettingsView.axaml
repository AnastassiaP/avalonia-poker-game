<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_poker_game.ViewModels"
             xmlns:conv="using:Avalonia_poker_game.Views.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="780"
             x:Class="Avalonia_poker_game.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Resources>
        <conv:BitmapAssetValueConverter x:Key="BitmapConv"/>
    </UserControl.Resources>

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*"
              Background="#0d2a0d" Height="44">
            <Button Grid.Column="0"
                    Content="← Back"
                    Command="{Binding BackCommand}"
                    Background="Transparent" Foreground="#aaaaaa"
                    FontSize="13" Padding="12,0"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="Settings"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Grid>
        
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel MaxWidth="520"
                        HorizontalAlignment="Center"
                        Margin="28,24,28,32"
                        Spacing="12">
                
                <TextBlock Text="AUDIO"
                           FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                           Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <TextBlock VerticalAlignment="Center" Text="Sound Effects" Margin="0,0,8,0"/>
                    <ToggleSwitch IsChecked="{Binding SoundEffects}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <TextBlock VerticalAlignment="Center" Text="Background Music" Margin="0,0,8,0"/>
                    <ToggleSwitch IsChecked="{Binding BackgroundMusic}"/>
                </StackPanel>
                
                <TextBlock Text="VISUALS"
                           FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                           Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <TextBlock VerticalAlignment="Center" Text="Show Animations" Margin="0,0,8,0"/>
                    <ToggleSwitch IsChecked="{Binding ShowAnimations}"/>
                </StackPanel>
                
                <TextBlock Text="CARD BACK"
                           FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                           Margin="0,8,0,0"/>
                <TextBlock Text="{Binding SelectedCardBack.DisplayName}"
                           FontSize="13" Margin="8,0,0,2"/>

                <ListBox ItemsSource="{Binding CardBackOptions}"
                         SelectedItem="{Binding SelectedCardBack}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CardBackOption">
                            <Border Width="46" Height="68" CornerRadius="4"
                                    ToolTip.Tip="{Binding DisplayName}"
                                    Margin="3">
                                <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}"
                                       Stretch="Fill"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <TextBlock Text="GAMEPLAY"
                           FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                           Margin="0,8,0,0"/>
                <CheckBox Content="Auto-fold on timeout"     IsChecked="{Binding AutoFold}"/>
                <CheckBox Content="Show hand strength hints" IsChecked="{Binding ShowHandHints}"/>
                <CheckBox Content="Allow chat during play"   IsChecked="{Binding AllowChatDuringPlay}"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
