<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_poker_game.ViewModels"
             xmlns:models="using:Avalonia_poker_game.Models"
             xmlns:conv="using:Avalonia_poker_game.Views.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="780"
             x:Class="Avalonia_poker_game.Views.GameView"
             x:DataType="vm:GameViewModel">

    <UserControl.Resources>
        <conv:BitmapAssetValueConverter x:Key="BitmapConv"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.playerBox">
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Background"      Value="#22000000"/>
            <Setter Property="Padding"         Value="8"/>
        </Style>
        <Style Selector="Border.playerBox.active">
            <Setter Property="BorderBrush" Value="Gold"/>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Width"        Value="110"/>
            <Setter Property="Height"       Value="46"/>
            <Setter Property="FontSize"     Value="15"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="Black">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto"
              Background="#0d2a0d" Height="44">

            <Button Grid.Column="0"
                    Content="← Menu"
                    Command="{Binding BackToMenuCommand}"
                    Background="Transparent" Foreground="#aaaaaa"
                    FontSize="13" Padding="12,0"
                    VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentPhase}"
                       Foreground="#FFD700" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"/>

            <TextBlock Grid.Column="3"
                       Text="{Binding StatusMessage}"
                       Foreground="White" FontSize="14"
                       VerticalAlignment="Center" Margin="16,0"/>
        </Grid>
        
        <Grid Grid.Row="1">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                <Grid Width="1200" Height="668">

                    <Image Source="avares://Avalonia-poker-game/Assets/Background/the_room.jpg"
                           Stretch="Fill"/>

                    <!-- AI characters pinned to chairs via absolute Canvas coords -->
                    <Canvas Width="1200" Height="668">

                        <!-- Tigeress - Left chair -->
                        <Border Canvas.Left="50" Canvas.Top="210"
                                Classes="playerBox"
                                Classes.active="{Binding Ai1.IsTurn}">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" Width="160">
                                <Image Source="{Binding Ai1.CharacterImagePath, Converter={StaticResource BitmapConv}}"
                                       Width="260" Height="260" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai1.Name}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai1.Chips, StringFormat='${0}'}" Foreground="#90EE90" FontSize="12" HorizontalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Center" IsVisible="{Binding !Ai1.IsEliminated}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" IsVisible="{Binding !Ai1.ShowCards}">
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Ai1.Hand}" IsVisible="{Binding Ai1.ShowCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Card">
                                                <Border Width="36" Height="52" CornerRadius="4" Background="White" ClipToBounds="True">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Text="Folded" Foreground="#FF6666" HorizontalAlignment="Center" FontSize="12" IsVisible="{Binding Ai1.IsFolded}"/>
                            </StackPanel>
                        </Border>

                        <!-- Mr. Pig - Center-left back chair -->
                        <Border Canvas.Left="320" Canvas.Top="80"
                                Classes="playerBox"
                                Classes.active="{Binding Ai2.IsTurn}">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" Width="160">
                                <Image Source="{Binding Ai2.CharacterImagePath, Converter={StaticResource BitmapConv}}"
                                       Width="240" Height="240" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai2.Name}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai2.Chips, StringFormat='${0}'}" Foreground="#90EE90" FontSize="12" HorizontalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Center" IsVisible="{Binding !Ai2.IsEliminated}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" IsVisible="{Binding !Ai2.ShowCards}">
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Ai2.Hand}" IsVisible="{Binding Ai2.ShowCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Card">
                                                <Border Width="36" Height="52" CornerRadius="4" Background="White" ClipToBounds="True">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Text="Folded" Foreground="#FF6666" HorizontalAlignment="Center" FontSize="12" IsVisible="{Binding Ai2.IsFolded}"/>
                            </StackPanel>
                        </Border>

                        <!-- Capitan - Center-right back chair -->
                        <Border Canvas.Left="700" Canvas.Top="80"
                                Classes="playerBox"
                                Classes.active="{Binding Ai4.IsTurn}">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" Width="160">
                                <Image Source="{Binding Ai4.CharacterImagePath, Converter={StaticResource BitmapConv}}"
                                       Width="240" Height="240" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai4.Name}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai4.Chips, StringFormat='${0}'}" Foreground="#90EE90" FontSize="12" HorizontalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Center" IsVisible="{Binding !Ai4.IsEliminated}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" IsVisible="{Binding !Ai4.ShowCards}">
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Ai4.Hand}" IsVisible="{Binding Ai4.ShowCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Card">
                                                <Border Width="36" Height="52" CornerRadius="4" Background="White" ClipToBounds="True">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Text="Folded" Foreground="#FF6666" HorizontalAlignment="Center" FontSize="12" IsVisible="{Binding Ai4.IsFolded}"/>
                            </StackPanel>
                        </Border>

                        <!-- Rat - Right chair -->
                        <Border Canvas.Left="970" Canvas.Top="224"
                                Classes="playerBox"
                                Classes.active="{Binding Ai3.IsTurn}">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" Width="160">
                                <Image Source="{Binding Ai3.CharacterImagePath, Converter={StaticResource BitmapConv}}"
                                       Width="260" Height="260" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai3.Name}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Ai3.Chips, StringFormat='${0}'}" Foreground="#90EE90" FontSize="12" HorizontalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Center" IsVisible="{Binding !Ai3.IsEliminated}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" IsVisible="{Binding !Ai3.ShowCards}">
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                        <Border Width="36" Height="52" CornerRadius="4" Background="#1a3f8f" ClipToBounds="True">
                                            <Image Source="{Binding CardBackPath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Ai3.Hand}" IsVisible="{Binding Ai3.ShowCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Card">
                                                <Border Width="36" Height="52" CornerRadius="4" Background="White" ClipToBounds="True">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Text="Folded" Foreground="#FF6666" HorizontalAlignment="Center" FontSize="12" IsVisible="{Binding Ai3.IsFolded}"/>
                            </StackPanel>
                        </Border>

                        <!-- Pot + community cards - center of table -->
                        <StackPanel Canvas.Left="350" Canvas.Top="310" Width="500" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PotText}"
                                       Foreground="#FFD700" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <ItemsControl ItemsSource="{Binding CommunityCards}" HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Card">
                                        <Border Width="70" Height="105" CornerRadius="6"
                                                Background="White" BorderBrush="#cccccc" BorderThickness="1">
                                            <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Player hand - bottom front chair -->
                        <StackPanel Canvas.Left="350" Canvas.Top="510" Width="500" Spacing="6" HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{Binding Human.Hand}" HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Card">
                                        <Border Width="90" Height="135" CornerRadius="8"
                                                Background="White" BorderBrush="#aaaaaa" BorderThickness="1">
                                            <Image Source="{Binding ImagePath, Converter={StaticResource BitmapConv}}" Stretch="Fill"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Human.Name}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Human.Chips, StringFormat='Chips: ${0}'}" Foreground="#90EE90" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>

                    </Canvas>
                </Grid>
            </Viewbox>
        </Grid>

        <!-- Action bar -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto"
              Background="#0a2a0a" MinHeight="68">

            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Spacing="10" Margin="16,0"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsPlayerTurn}">
                <TextBlock Text="Raise:" Foreground="White"
                           VerticalAlignment="Center" FontSize="14"/>
                <Slider Value="{Binding RaiseAmount}"
                        Minimum="{Binding MinRaise}"
                        Maximum="{Binding MaxRaise}"
                        Width="220"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{Binding RaiseAmount, StringFormat='${0}'}"
                           Foreground="#FFD700" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" MinWidth="60"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        Spacing="10" Margin="16,10"
                        IsVisible="{Binding IsPlayerTurn}">
                <Button Classes="action" Content="Fold"
                        Command="{Binding FoldCommand}"
                        Background="#8B0000" Foreground="White"/>
                <Button Classes="action" Content="{Binding CallText}"
                        Command="{Binding CheckCallCommand}"
                        Background="#1a5c1a" Foreground="White"/>
                <Button Classes="action" Content="Raise"
                        Command="{Binding RaiseCommand}"
                        Background="#8B6914" Foreground="White"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="New Hand"
                    Command="{Binding NewHandCommand}"
                    IsVisible="{Binding ShowNewHandButton}"
                    Width="160" Height="46" FontSize="15"
                    Background="#2a5a8a" Foreground="White"
                    Margin="16,10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</UserControl>
